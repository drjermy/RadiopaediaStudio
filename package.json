{
  "name": "pacs-anonymizer",
  "version": "0.1.0",
  "description": "DICOM anonymiser desktop app",
  "main": "dist/main/index.js",
  "scripts": {
    "build:backend": "cd backend && .venv/bin/pyinstaller --noconfirm --clean backend.spec",
    "build:frontend": "tsc -p tsconfig.json",
    "build": "npm run build:frontend",
    "dev": "tsc -p tsconfig.json && electron .",
    "pack": "npm run build:backend && npm run build:frontend && electron-builder --mac --dir",
    "dist": "npm run build:backend && npm run build:frontend && electron-builder --mac"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.0"
  }
}
