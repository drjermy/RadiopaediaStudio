.DS_Store

# Claude Code worktrees + task transcripts
.claude/

# Local DICOM test data — don't commit
dcm/

# Python
backend/.venv/
backend/**/__pycache__/
backend/**/*.egg-info/
backend/build/
backend/dist/
.pytest_cache/

# Bundled viewer output (colocated with src/renderer/index.html so the
# file:// script tag resolves cleanly in the packaged app)
src/renderer/viewer.bundle.js
src/renderer/*.wasm
src/renderer/decodeImageFrameWorker.js

# Compiled renderer output (produced by `tsc -p tsconfig.renderer.json`,
# colocated with index.html for the same reason).
src/renderer/renderer.js
src/renderer/renderer.js.map
# api.ts is types-only; tsc still emits empty JS siblings we don't ship.
src/shared/api.js
src/shared/api.js.map

# Radiopaedia OAuth client credentials baked at build time from env vars.
# See src/main/radiopaedia-config.example.ts and
# scripts/write-radiopaedia-config.mjs.
src/main/radiopaedia-config.ts

# Token cache written by scripts/smoke-test-radiopaedia-upload.mjs after a
# successful refresh-token exchange, so you don't have to paste a fresh
# access token on every run. Contains a live access_token + refresh_token —
# never commit.
.radiopaedia-tokens.json
